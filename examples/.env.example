# Greybeam MCP environment variables (alternative configuration path).
#
# The recommended setup is a single YAML file (see examples/greybeam.yaml
# or run `uvx greybeam-mcp init`). These env vars exist for container /
# k8s deployments where secrets are mounted as env, not as files. They
# fill in any field not set in the YAML.
#
# When using env vars, pass them via your Claude client config (the "env"
# block in claude_desktop_config.json, or `claude mcp add -e KEY=VAL`).
# Do NOT export them in your shell expecting the MCP server to inherit
# them — Claude Desktop / Claude Code spawns the subprocess fresh.

# Snowflake user (required).
SNOWFLAKE_USER=your_user

# Pick exactly one of the following auth methods.

# 1. Key-pair auth via file (RECOMMENDED — Snowflake's preferred method).
#    Snowflake is deprecating password auth; use this for new setups.
SNOWFLAKE_PRIVATE_KEY_FILE=/absolute/path/to/rsa_key.p8
# Optional — only if the key is encrypted.
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your_passphrase

# 2. Key-pair auth via inline PEM (for environments without a writable disk).
# SNOWFLAKE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# 3. SSO via browser. Requires a configured SAML2 integration on the account.
# SNOWFLAKE_AUTHENTICATOR=externalbrowser

# 4. Password (DEPRECATED by Snowflake — avoid for new setups).
# SNOWFLAKE_PASSWORD=your_password
